pipeline {
    agent {
        label 'docker'
    }

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['staging', 'production'],
            description: 'Choose the environment to deploy to'
        )

        string(
            name: 'VERSION',
            defaultValue: '1.0.0',
            description: 'Enter the version number to deploy'
        )

        booleanParam(
            name: 'RUN_TESTS',
            defaultValue: true,
            description: 'Run tests before deployment?'
        )
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Checking out source code..."
                git branch: 'main', url: 'https://github.com/AbdelrhmanEzzat/digi-jenkins.git'
            }
        }

        stage('Install') {
            steps {
                echo "Installing dependencies..."
                sh 'npm install'
            }
        }

        stage('Test') {
            when {
                expression {
                    return params.RUN_TESTS == true
                }
            }
            steps {
                echo "Running tests..."
                sh 'npm test'
            }
        }

        stage('Approval') {
            when {
                expression {
                    return params.ENVIRONMENT == 'production'
                }
            }
            steps {
                timeout(time: 1, unit: 'MINUTES') {
                    input message: "Deploy version ${params.VERSION} to PRODUCTION?",
                          ok: "Yes, Deploy!"
                }
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploying version ${params.VERSION} to ${params.ENVIRONMENT}..."
                sh """
                    echo "Deploying app..."
                    echo "Environment: ${params.ENVIRONMENT}"
                    echo "Version: ${params.VERSION}"
                    echo "Deployment completed successfully"
                """
            }
        }
    }

    post {
        success {
            echo "Deployment of version ${params.VERSION} to ${params.ENVIRONMENT} completed successfully!"
        }

        failure {
            echo "Pipeline failed."
        }

        always {
            echo "Build finished."
        }
    }
}